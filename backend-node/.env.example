# Backend environment example
NODE_ENV=development
PORT=8001

# Database
MONGO_URL=mongodb+srv://username:password@cluster0.mongodb.net
DB_NAME=dangi_innovation_lab

# Auth
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRE=7d
CSRF_SECRET=replace_with_a_long_random_csrf_secret
CSRF_TOKEN_TTL_MS=7200000

# Seed/default admin account
ADMIN_EMAIL=admin@dangiinnovationlab.com
ADMIN_PASSWORD=replace_with_strong_admin_password

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
PUBLIC_FORM_WINDOW_MS=900000
PUBLIC_FORM_MAX_REQUESTS=8
UPLOADS_CACHE_MAX_AGE=7d
UPLOADS_CACHE_MAX_AGE_SECONDS=604800

# SEO and sitemap
# Frontend canonical domain used by backend sitemap + SEO ping jobs
FRONTEND_URL=https://dangiinnovationlab.com

# Retry worker interval for queued SEO ping logs (ms)
SEO_RETRY_WORKER_INTERVAL_MS=300000

# Modern mode default: false means no deprecated legacy external sitemap ping endpoints
SEO_ENABLE_LEGACY_PING=false
INTEGRATION_API_KEY=replace_with_strong_integration_key

# Legacy ping retry controls
SEO_PING_MAX_RETRIES=4
SEO_PING_RETRY_BASE_MS=300000
