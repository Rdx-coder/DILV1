# Frontend environment example

# Public backend base URL used by app API calls
REACT_APP_BACKEND_URL=http://localhost:8001
REACT_APP_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Public frontend canonical URL used for SEO tags and schema URLs
REACT_APP_FRONTEND_URL=https://dangiinnovationlab.com

# Optional (build-time sitemap generation)
# Preferred backend URL for fetching published blogs into frontend/public/sitemap.xml
SITEMAP_BACKEND_URL=http://localhost:8001
